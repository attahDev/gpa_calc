# .env.example
# Copy this file to .env and fill in real values for local development.
# .env is in .gitignore — never commit real values to GitHub.
# On Render, set these in the dashboard under Environment Variables.

# PostgreSQL connection string
# Local (docker-compose): postgresql://gpa_user:gpa_pass@localhost:5432/gpa_db
# Render: provided automatically when you link a Render Postgres database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string used to sign JWT tokens — never share this
# Generate one: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=replace_with_a_long_random_string

# JWT token lifetime
JWT_EXPIRY=7d

# Frontend URL for CORS — must match exactly, no trailing slash
# Local: http://localhost:5500  (Live Server default)
# Production: https://your-app.onrender.com
ALLOWED_ORIGIN=http://localhost:5500

# "development" enables /docs and SQL echo logging
# "production" disables /docs
ENVIRONMENT=development